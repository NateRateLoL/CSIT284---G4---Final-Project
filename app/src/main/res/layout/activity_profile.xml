<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.terrance.screens.profile.ProfileActivity">

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:id="@+id/header">

        <View
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#5e3023"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            android:id="@+id/header_background"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Profile"
            android:layout_marginTop="45dp"
            android:layout_marginLeft="15dp"
            android:textSize="30dp"
            android:layout_marginBottom="20dp"
            android:textColor="@color/white"
            android:fontFamily="serif-monospace"
            android:textStyle="bold"/>

    </RelativeLayout>

    <RelativeLayout
        android:id="@+id/source"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/header"
        android:layout_centerVertical="true"
        android:layout_marginTop="0dp"
        android:background="#ead2ac">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerHorizontal="true"
            android:layout_margin="30dp"
            android:background="@drawable/corners"
            android:elevation="25dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/text_go_back"
                android:layout_margin="15dp"
                android:fontFamily="serif-monospace"
                android:text="← Go Back"
                android:textSize="20dp"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:id="@+id/text_save"
                android:layout_margin="15dp"
                android:padding="5dp"
                android:layout_alignParentRight="true"
                android:fontFamily="serif-monospace"
                android:text="Save"
                android:textSize="20dp"
                android:textStyle="bold"/>

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="80dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="50dp">

                <TextView
                    android:id="@+id/text_username"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Username"
                    android:textSize="15dp"/>

                <EditText
                    android:id="@+id/edit_username"
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_username"
                    android:textSize="15dp"/>

                <TextView
                    android:id="@+id/text_first_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/edit_username"
                    android:text="First Name"
                    android:textSize="15dp"/>

                <EditText
                    android:id="@+id/edit_first_name"
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_first_name"
                    android:textSize="15dp"/>

                <TextView
                    android:id="@+id/text_middle_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/edit_first_name"
                    android:text="Middle Name"
                    android:textSize="15dp"/>

                <EditText
                    android:id="@+id/edit_middle_name"
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_middle_name"
                    android:textSize="15dp"/>

                <TextView
                    android:id="@+id/text_last_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/edit_middle_name"
                    android:text="Last Name"
                    android:textSize="15dp"/>

                <EditText
                    android:id="@+id/edit_last_name"
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_last_name"
                    android:textSize="15dp"/>

                <TextView
                    android:id="@+id/text_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/edit_last_name"
                    android:text="Email"
                    android:textSize="15dp"/>

                <EditText
                    android:id="@+id/edit_email"
                    android:layout_width="250dp"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/text_email"
                    android:textSize="15dp"/>

            </RelativeLayout>
        </RelativeLayout>
    </RelativeLayout>
</RelativeLayout>