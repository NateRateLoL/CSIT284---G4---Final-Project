<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context="com.terrance.screens.register.RegisterActivity"
    android:background="#ead2ac">

    <View
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/round"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:elevation="25dp"/>

    <RelativeLayout
        android:layout_width="300dp"
        android:layout_height="500dp"
        android:id="@+id/source"
        android:background="@drawable/corners"
        android:layout_centerHorizontal="true"
        android:layout_centerVertical="true"
        android:elevation="30dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Let's Make IT!"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="40dp"
            android:textSize="23dp"
            android:id="@+id/register_text"
            android:fontFamily="serif-monospace"
            android:textStyle="bold"/>

        <EditText
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/register_text"
            android:hint="Email"
            android:layout_marginTop="25dp"
            android:layout_centerHorizontal="true"
            android:id="@+id/register_input_email"/>

        <EditText
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/register_input_email"
            android:hint="Password"
            android:layout_marginTop="25dp"
            android:layout_centerHorizontal="true"
            android:id="@+id/register_input_password"/>

        <EditText
            android:layout_width="250dp"
            android:layout_height="wrap_content"
            android:layout_below="@id/register_input_password"
            android:hint="Re-enter Password"
            android:layout_marginTop="25dp"
            android:layout_centerHorizontal="true"
            android:id="@+id/register_input_confirm_password"/>

        <Button
            android:layout_width="250dp"
            android:id="@+id/button_confirm"
            android:layout_height="wrap_content"
            android:text="Confirm"
            android:textSize="40dp"
            android:layout_centerHorizontal="true"
            android:layout_below="@id/register_input_confirm_password"
            android:layout_marginTop="40dp"
            android:fontFamily="serif-monospace"
            android:backgroundTint="#5e3023"
            android:textColor="@color/white"/>

    </RelativeLayout>
</RelativeLayout>